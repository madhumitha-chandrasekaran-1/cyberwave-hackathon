# ──────────────────────────────────────────────
# Cyberwave Robot Arm API
# ──────────────────────────────────────────────
# Obtain from https://cyberwave.com/dashboard
CYBERWAVE_API_KEY=
CYBERWAVE_BASE_URL=https://api.cyberwave.com

# ──────────────────────────────────────────────
# Smallest.ai (STT + TTS)
# ──────────────────────────────────────────────
# Obtain from https://smallest.ai/dashboard
SMALLEST_API_KEY=

# ──────────────────────────────────────────────
# Anthropic (Claude vision for exercise evaluation)
# ──────────────────────────────────────────────
# Obtain from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# Toolhouse (agent orchestration)
# ──────────────────────────────────────────────
# Obtain from https://app.toolhouse.ai/settings/api-keys
TOOLHOUSE_API_KEY=

# ──────────────────────────────────────────────
# Camera
# ──────────────────────────────────────────────
# 0 = first/default webcam; change if using USB or rover cam
CAMERA_INDEX=0
