# ──────────────────────────────────────────────
# Cyberwave Robot Arm API
# ──────────────────────────────────────────────
# Obtain from https://cyberwave.com/dashboard
CYBERWAVE_API_KEY=
CYBERWAVE_BASE_URL=https://api.cyberwave.com

# ──────────────────────────────────────────────
# Smallest.ai (STT + TTS)
# ──────────────────────────────────────────────
# Obtain from https://smallest.ai/dashboard
SMALLEST_API_KEY=

# ──────────────────────────────────────────────
# OpenAI (GPT-4o Vision)
# ──────────────────────────────────────────────
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# Camera
# ──────────────────────────────────────────────
# 0 = first/default webcam; change if using USB or rover cam
CAMERA_INDEX=0
